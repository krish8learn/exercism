{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Current SQL Test",
            "type": "shell",
            "command": "sqlite3 < \"${file}\"",
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "focus": true
            },
            "problemMatcher": []
        }
    ]
}